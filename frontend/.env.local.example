# Для локального запуска: npm run dev
# Backend: docker compose up -d backend postgres redis (порт API на хосте 8001) или uvicorn на 8001.
# По умолчанию прокси уже бьёт в http://127.0.0.1:8001 — строку ниже можно не задавать.
# INTERNAL_BACKEND_ORIGIN=http://127.0.0.1:8001
NEXT_PUBLIC_API_URL=/api/v1
