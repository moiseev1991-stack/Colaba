ENVIRONMENT=development
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production

# --- База: в Docker используйте хост ``postgres``; uvicorn на хосте — ``127.0.0.1`` и порт Postgres (в compose обычно 5433:5432).
DATABASE_URL=postgresql+asyncpg://leadgen_user:leadgen_password@postgres:5432/leadgen_db
DATABASE_URL_SYNC=postgresql://leadgen_user:leadgen_password@postgres:5432/leadgen_db
# Локальный бэкенд без Docker-сети, Postgres только через ``docker compose up -d postgres``:
# DATABASE_URL=postgresql+asyncpg://leadgen_user:leadgen_password@127.0.0.1:5433/leadgen_db
# DATABASE_URL_SYNC=postgresql://leadgen_user:leadgen_password@127.0.0.1:5433/leadgen_db

REDIS_URL=redis://redis:6379/0
# Локально: redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000

# Поисковые провайдеры
# По умолчанию используется DuckDuckGo (бесплатный, без ключа)
# Для использования Яндекс XML API (опционально) раскомментируйте и заполните:

# Yandex Cloud Search API (провайдер «Яндекс XML»)
# https://yandex.cloud/ru/docs/search-api/quickstart
# YANDEX_XML_FOLDER_ID=идентификатор_каталога
# YANDEX_XML_KEY=API-ключ_сервисного_аккаунта

# SerpAPI (deprecated - используйте DuckDuckGo или Yandex XML)
# SERPAPI_KEY=your_serpapi_key

# Прокси для HTML-провайдеров (Яндекс, Google) — обход блокировок
# USE_PROXY=true
# PROXY_URL=http://proxy.example.com:8080
# PROXY_LIST=http://proxy1.example.com:8080,http://proxy2.example.com:8080,socks5://proxy3.example.com:1080
