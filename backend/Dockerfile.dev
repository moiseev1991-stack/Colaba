# Development Dockerfile for Backend

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt .
COPY requirements-dev.txt .

# Install Python dependencies — BuildKit cache mount lets retries reuse partial downloads
# (Docker bridge on Windows/WSL2 can drop SSL mid-stream on big wheels)
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --retries 20 --timeout 180 --upgrade pip && \
    pip install --retries 20 --timeout 180 -r requirements-dev.txt

# Copy application code
COPY . .

# Expose port
EXPOSE 8000

# Default command (will be overridden in docker-compose.yml)
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
